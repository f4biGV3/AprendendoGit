<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Landing Page - Aula Flexbox</title>
        <link rel="stylesheet" href="style.css" />
    </head>


    <body>
        <header class="site-header">
            <div class="container header-content">
                <a class="logo" href="#">FlexLab</a>

                <nav class="nav">
                    <a class="nav-link" href="#recursos">Recursos</a>
                    <a class="nav-link" href="#beneficios">Benefícios</a>
                    <a class="nav-link" href="#contato">Contato</a>
                </nav>

                <a class="btn btn-primary" href="#contato">Começar</a>
            </div>
        </header>

        <main>
            <section class="hero">
                <div class="container hero-content">
                    <div class="hero-text">
                        <p class="badge">Aula 06 • Flexbox</p>
                        <h1 class="hero-title">Construa layouts de verdade com CSS Flexbox</h1>
                        <p class="hero-subtitle">Transforme uma página solta em um layout estruturado.</p>

                        <div class="hero-actions">
                            <a class="btn btn-primary" href="#beneficios">Ver benefícios</a>
                            <a class="btn btn-outline" href="#recursos">Ver recursos</a>
                        </div>
                    </div>

                    <div class="hero-media">
                        <div class="mockup">
        
                            <div class="mockup-top"></div>
                                <div class="mockup-body">
                                    <div class="mockup-line"></div>
                                        <div class="mockup-line short"></div>
                                </div>
                        </div>
                    </div>
                </div>
        </section>


    <section id="beneficios" class="section">
    <div class="container">
    <div class="cards">
    <article class="card">
    <h3>Header alinhado</h3>
    <p>Logo em um canto e menu no outro.</p>
    </article>
    <article class="card">
    <h3>Hero organizado</h3>
    <p>Texto e imagem lado a lado.</p>
    </article>
    <article class="card">
    <h3>Responsivo</h3>
    <p>Quebra de linha automática.</p>
    </article>
    </div>
    </div>
    </section>
    </main>
    <footer class="site-footer">
    <div class="container footer-content">
    <p>© 2026 FlexLab</p>
    <div class="footer-right">
    <a href="#">IG</a>
    <a href="#">GH</a>
    </div>
    </div>
    </footer>
    </body>
</html>